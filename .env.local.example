# ============================================================
# AKLAB — пример локальной среды разработки
#
# Использование:
#   cp .env.local.example .env
#   отредактируйте .env под себя
# ============================================================

# === General ===
NODE_ENV=development
HOST=0.0.0.0
PORT_API=1338
PORT_APP=5174

# === Strapi Security ===
# Для локальной разработки можно оставить dev-значения ниже.
# Для прода сгенерируйте уникальные:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=dev_key_1,dev_key_2,dev_key_3,dev_key_4
API_TOKEN_SALT=dev_salt_change_me
ADMIN_JWT_SECRET=dev_jwt_secret_change_me
TRANSFER_TOKEN_SALT=dev_transfer_salt_change_me
JWT_SECRET=dev_jwt_change_me
ENCRYPTION_KEY=dev_encryption_key_change_me
ADMIN_AUTH_SECRET=dev_admin_auth_change_me

# === Database (локальный SQLite) ===
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# === Strapi Admin (создаётся автоматически при первом старте api) ===
STRAPI_ADMIN_EMAIL=admin@aklab.local
STRAPI_ADMIN_PASSWORD=admin

# === Test user (bootstrap, только в dev) ===
TEST_USER_EMAIL=test@aklab.local
TEST_USER_PASSWORD=test1234

# === Frontend ===
# В dev-режиме Vite proxy проксирует /api -> http://localhost:1338,
# так что фронт может ходить по относительному /api/users/me.
# VITE_API_URL используется для прод-сборки и как fallback.
VITE_API_URL=http://localhost:1338/api

# === Deploy Notifications (опционально) ===
# Нужно для scripts/deploy-prod.sh — присылает уведомления в Telegram.
# TELEGRAM_BOT_TOKEN=xxx
# TELEGRAM_CHAT_ID=xxx
