# ============================================================
# TODOIT — Шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значения
# cp .env.template .env
# ============================================================

# === General ===
NODE_ENV=development
HOST=0.0.0.0
PORT_API=1338
PORT_APP=5174

# === Strapi Security (КРИТИЧНО) ===
# Сгенерируйте уникальные значения: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APP_KEYS — массив из 4 ключей через запятую
APP_KEYS=change_me_key_1,change_me_key_2,change_me_key_3,change_me_key_4
API_TOKEN_SALT=change_me_api_token_salt
ADMIN_JWT_SECRET=change_me_admin_jwt_secret
TRANSFER_TOKEN_SALT=change_me_transfer_token_salt
JWT_SECRET=change_me_jwt_secret
ENCRYPTION_KEY=change_me_encryption_key
ADMIN_AUTH_SECRET=change_me_admin_auth_secret

# === Database ===
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# === Strapi Admin (автоматическое создание при старте) ===
STRAPI_ADMIN_EMAIL=admin@todoit.ru
STRAPI_ADMIN_PASSWORD=change_me_admin_password

# === Test Users (автоматическое создание при старте) ===
TEST_USER_EMAIL=test@todoit.ru
TEST_USER_PASSWORD=change_me_test_password

# === Frontend (VITE_ переменные доступны в браузере) ===
VITE_API_URL=http://localhost:1338/api

# === Deploy Notifications ===
TELEGRAM_BOT_TOKEN=change_me_bot_token
TELEGRAM_CHAT_ID=change_me_chat_id
