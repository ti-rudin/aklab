{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Property"
  },
  "options": {
    "draftAndPublish": false
  },
  "indexes": [
    {
      "name": "properties_source_external_id_unique",
      "unique": true,
      "columns": ["source", "external_id"]
    },
    {
      "name": "properties_status_idx",
      "columns": ["status"]
    },
    {
      "name": "properties_city_idx",
      "columns": ["city"]
    },
    {
      "name": "properties_is_undervalued_idx",
      "columns": ["is_undervalued"]
    },
    {
      "name": "properties_property_type_idx",
      "columns": ["property_type"]
    },
    {
      "name": "properties_focus_score_idx",
      "columns": ["focus_score"]
    },
    {
      "name": "properties_focus_composite_idx",
      "columns": ["focus_score", "city", "property_type"]
    },
    {
      "name": "properties_created_at_idx",
      "columns": ["created_at"]
    }
  ],
  "pluginOptions": {},
  "attributes": {
    "source": {
      "type": "enumeration",
      "enum": [
        "fedresurs",
        "aggregator-bankrot",
        "torgi-gov",
        "investmoscow",
        "invest-mosreg",
        "roseltorg",
        "fabrikant",
        "alfalot",
        "etprf",
        "sberbank-ast",
        "m-ets"
      ],
      "required": true
    },
    "external_id": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "text"
    },
    "city": {
      "type": "enumeration",
      "enum": ["moscow", "mo", "other"],
      "default": "moscow"
    },
    "area_sqm": {
      "type": "decimal"
    },
    "price": {
      "type": "decimal"
    },
    "price_per_sqm": {
      "type": "decimal"
    },
    "property_type": {
      "type": "enumeration",
      "enum": ["office", "warehouse", "retail", "production", "free_purpose", "other"],
      "default": "other"
    },
    "auction_type": {
      "type": "enumeration",
      "enum": ["bankruptcy", "privatization", "marketplace"],
      "default": "bankruptcy"
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "in_progress", "viewed", "rejected"],
      "default": "new",
      "required": true
    },
    "is_undervalued": {
      "type": "boolean",
      "default": null
    },
    "deviation_percent": {
      "type": "decimal"
    },
    "manual_price_per_sqm": {
      "type": "decimal"
    },
    "published_at_source": {
      "type": "datetime"
    },
    "description": {
      "type": "text"
    },
    "contacts": {
      "type": "text"
    },
    "photo_urls": {
      "type": "json"
    },
    "photos": {
      "type": "json"
    },
    "photos_downloaded": {
      "type": "boolean",
      "default": false
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-comment.user-comment",
      "mappedBy": "property"
    },
    "focus_score": {
      "type": "integer",
      "default": 0,
      "required": true
    },
    "tags": {
      "type": "json",
      "default": []
    },
    "minimum_price": {
      "type": "decimal"
    },
    "first_seen_at": {
      "type": "datetime"
    },
    "property_events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::property-event.property-event",
      "mappedBy": "property"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    }
  }
}
